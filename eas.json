{
  "cli": {
    "version": ">=16.0.0",
    "requireCommit": false,
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "node": "22.13.0",
      "autoIncrement": true,
      "channel": "production",
      "distribution": "store",
      "android": {
        "buildType": "aab"
      },
      "cache": {
        "key": "v3-sdk57",
        "customPaths": ["node_modules"]
      }
    },
    "preview": {
      "node": "22.13.0",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "key": "v3-sdk57"
      }
    },
    "development": {
      "node": "22.13.0",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
